<!DOCTYPE html>
<html>
<head>
    <title>Company Form</title>
    <link rel="stylesheet" type="text/css" href="/css/style.css" />

</head>
<body>
    <%- include('partials/navbar') %>
    <h1>Input Company Data</h1>
    <form action="/submit-company" method="POST">
        <label for="name">Name:</label>
        <input type="text" id="name" name="comp_name" required><br><br>
        <label for="url">URL:</label>
        <input type="url" id="url" name="comp_url" required><br><br>
        <label for="industry">Industry:</label>
        <input type="text" id="industry" name="comp_indust" required><br><br>
        <button type="submit">Submit</button>
    </form>
</body>
</html>
